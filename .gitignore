# ============================================================
# 機密ファイル — 絶対にコミットしない（最重要）
# ============================================================

# 実取引データ（許可証・PO・PL の現物）
docs/粗利表用/

# シークレット類
secrets/
*.pem
*.key
service_account*.json
.env
.env.*
!.env.example

# 認証トークンキャッシュ
.credentials/
*credentials*.json
token.json

# ============================================================
# ランタイムデータ
# ============================================================

# Web実行時のアップロード・出力・ログ・ジョブ状態
data/
inputs/
outputs/
logs/
jobs/

# Excel 一時ファイル（開いている間に Excel が作る隠しファイル）
~$*
*.tmp

# ============================================================
# Python
# ============================================================

# バイトコードキャッシュ
__pycache__/
*.py[cod]
*$py.class
*.so

# 仮想環境
.venv/
venv/
env/
ENV/

# パッケージング
*.egg
*.egg-info/
build/
dist/
wheels/
*.whl

# テスト・型・lint キャッシュ
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/

# ============================================================
# Node / Frontend（将来のため）
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================
# エディタ / IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# その他
# ============================================================
*.bak
*.log
